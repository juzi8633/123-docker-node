// schema.prisma

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 剧集/电影主表
// [修改] 增加了 originalLanguage 和 originCountry 以支持分类
model SeriesMain {
  tmdbId          Int      @id @map("tmdb_id")
  name            String
  year            String?
  type            String   // 'movie' or 'tv'
  genres          String?  // 逗号分隔的 Genre ID，如 "16,18,35"
  
  // [新增] 原声语言 (如 'zh', 'en', 'ja') - 对应 YAML 中的 original_language
  originalLanguage String? @map("original_language") 
  
  // [新增] 产地/国家 (如 'CN', 'US', 'JP') - 对应 YAML 中的 origin_country
  originCountry    String? @map("origin_country")

  lastUpdated     DateTime @default(now()) @map("last_updated")
  
  episodes        SeriesEpisode[]

  @@index([type, originalLanguage])
  @@index([type, genres])
  @@map("series_main")
}

// 剧集分集/文件表
model SeriesEpisode {
  id          Int      @id @default(autoincrement())
  tmdbId      Int      @map("tmdb_id")
  season      Int?
  episode     Int?
  cleanName   String   @map("clean_name")
  size        BigInt
  etag        String
  score       Int      @default(0)
  type        String   // 'video' or 'subtitle'
  createdAt   DateTime @default(now()) @map("created_at")
  
  // [本次新增核心字段] 
  // 存储生成的 strm 内容的哈希值 (MD5)
  // 用于比对配置或域名是否变更，变更时才重写文件，实现零 I/O 同步
  strmHash    String?  @map("strm_hash")

  series      SeriesMain @relation(fields: [tmdbId], references: [tmdbId], onDelete: Cascade)

// [性能优化] 核心查询索引
  // 场景1: 查某部电影的所有文件 -> where tmdbId
  // 场景2: 查某部剧某季的所有文件 -> where tmdbId, season
  @@index([tmdbId, season, type]) 
  @@index([tmdbId, type])
  
  // [性能优化] 文件名反查索引 (用于 handleGet)
  @@index([tmdbId, cleanName])
  @@index([tmdbId, season, episode])
  @@map("series_episodes")
}

// 待处理任务表 (保持不变)
model PendingEpisode {
  id          Int      @id @default(autoincrement())
  etag        String
  tmdbId      Int      @map("tmdb_id")
  season      Int
  episode     Int
  cleanName   String   @map("clean_name")
  size        BigInt
  score       Int
  type        String
  sourceType  String   @map("source_type") // '123', '189', 'quark', 'openlist'
  sourceRef   String?  @map("source_ref")
  retryCount  Int      @default(0) @map("retry_count")
  taskId      String?  @map("task_id")
  createdAt   DateTime @default(now()) @map("created_at")
  nextRetryAt BigInt   @default(0) @map("next_retry_at")
  
  @@index([etag])
  @@map("pending_episodes")
}

// [新增] 系统配置表
// 用于存储全局配置 (TMDB Key, Cookie, Token 等)，替代 localStorage
model SystemConfig {
  key         String   @id  // 配置键，如 'tmdb_key', 'quark_cookie'
  value       String        // 配置值
  description String?       // 备注说明 (可选)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("system_configs")
}